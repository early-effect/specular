#!/usr/bin/env bash
# Reject commits that would fail CI's scalafmtCheckAll.
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

if ! command -v sbt >/dev/null 2>&1; then
  echo "pre-commit: sbt not found on PATH; cannot run scalafmtCheckAll" >&2
  exit 1
fi

echo "pre-commit: scalafmtCheckAll…"
if ! sbt -batch -no-colors scalafmtCheckAll; then
  echo >&2
  echo "pre-commit: scalafmtCheckAll failed." >&2
  echo "  Fix with:  sbt scalafmtAll" >&2
  echo "  Then re-stage and commit." >&2
  exit 1
fi
